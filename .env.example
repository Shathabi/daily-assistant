# Copy this file to .env and fill in your actual API keys

# Google APIs (Gmail + Calendar)
# Get these from: https://console.cloud.google.com
GOOGLE_CLIENT_ID=your_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret_here

# LinkedIn Credentials
LINKEDIN_EMAIL=shathabi@gmail.com
LINKEDIN_PASSWORD=your_linkedin_password

# iMessage Delivery
# Use your phone number (e.g., +12345678901) or Apple ID email
YOUR_PHONE_NUMBER=+12345678901
# Or use your Apple ID email:
# YOUR_IMESSAGE_ID=shathabi@gmail.com

# Claude API (for summarization)
# Get key from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Timezone
TIMEZONE=America/New_York  # Eastern Time

# Job Search Integration
ABIS_SEARCH_PATH=/Users/abiravindra/abis-search

# Email News Sources
WORLD_NEWS_SENDERS=CNN,Tangle,Robinhood
GROWTH_MARKETING_SENDERS=Kyle Poyar,Emily Kramer,Platformer,Operator,Alex Johnson

# Preferences
MAX_EMAILS_TO_SHOW=10
MAX_LINKEDIN_MESSAGES=5
MAX_NEWS_ITEMS_PER_CATEGORY=3
MAX_JOB_UPDATES=3
BRIEF_SEND_TIME=06:00  # 6:00 AM ET
